
PORT=3050
# ------------------URL---------------------------------------------------
API_BASE_PATH=/v1

# ------------------POSTGRES-----------------------------------------------
# Usadas por la libreria @tigo/postgres-connector.
# Opcion 1: variables individuales
P_DB_HOST=localhost
P_DB_PORT=5432
P_DB_NAME=mydatabase
P_DB_USER=postgres
P_DB_PASSWORD=postgres123
P_DB_MAX_CONNECTIONS=10
# Opcion 2 (tiene prioridad si esta definida):
# P_DB_CONNECTION_STRING=postgresql://postgres:postgres123@localhost:5432/mydatabase

# ------------------REDIS---------------------------------------------------
# Usadas por la libreria @tigo/redis-connector (eliminar si no se usa).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Kafka
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_CLIENT_ID=project-template
KAFKA_GROUP_ID=project-template
KAFKA_TOPIC=example-topic